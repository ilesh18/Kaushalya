# Normalize all line endings to LF in the repo
* text=auto eol=lf

# Explicitly set JS/JSX/CSS/JSON to LF
*.js   text eol=lf
*.jsx  text eol=lf
*.ts   text eol=lf
*.tsx  text eol=lf
*.css  text eol=lf
*.json text eol=lf
*.md   text eol=lf
*.html text eol=lf
*.env  text eol=lf

# Binary files - no conversion
*.png  binary
*.jpg  binary
*.jpeg binary
*.ico  binary
*.webp binary
*.svg  binary
*.woff binary
*.woff2 binary
